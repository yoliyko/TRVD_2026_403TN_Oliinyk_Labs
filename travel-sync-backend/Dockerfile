# 1. Беремо готовий образ з Node.js версії 20 (легка версія alpine)
FROM node:20-alpine

# 2. Створюємо папку всередині цієї віртуальної системи
WORKDIR /usr/src/app

# 3. Копіюємо файли зі списком бібліотек
COPY package*.json ./

# 4. Запускаємо встановлення бібліотек всередині контейнера
RUN npm install

# 5. Копіюємо решту файлів нашого коду
COPY . .

# 6. Компілюємо TypeScript у звичайний JavaScript (папка dist)
RUN npm run build

# 7. Кажемо, що цей контейнер буде слухати порт 3000
EXPOSE 3000

# 8. Команда, яка запустить бекенд
CMD ["npm", "run", "start:prod"]